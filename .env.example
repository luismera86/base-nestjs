# ── App ─────────────────────────────────────────────────────────────
# development | test | production
NODE_ENV=development
PORT=3000
API_PREFIX=api
# Orígenes permitidos para CORS, separados por coma. Vacío = no permite orígenes cross-origin.
CORS_ORIGINS=http://localhost:5173

# ── Base de datos (PostgreSQL) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=base_nestjs
DB_SSL=false

# ── JWT ─────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Deben ser distintos entre sí.
# Generar con: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-with-openssl-rand-hex-32-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-with-openssl-rand-hex-32-refresh
JWT_REFRESH_EXPIRES_IN=7d

# Tamaño máximo del body JSON aceptado (100kb, 1mb, ...).
BODY_LIMIT=100kb

# ── Cookies de auth ─────────────────────────────────────────────────
# Flag Secure (solo HTTPS). Default: true en producción, false en dev.
# COOKIE_SECURE=true

# ── Rate limiting global (ventana en ms / peticiones por ventana) ───
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Proxies inversos de confianza delante de la app (nginx/Apache/ALB = 1,
# Cloudflare + nginx = 2, sin proxy = 0). Necesario en producción para que
# el rate limiting cuente por usuario real y no contra la IP del proxy.
TRUST_PROXY=0

# ── Seed del primer admin (pnpm seed) ───────────────────────────────
# Debe cumplir la política de contraseñas (8-128, minúscula, mayúscula,
# número y carácter especial). El seed es idempotente.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Change-me-123!

# ── Correo (SMTP) ───────────────────────────────────────────────────
# Sin MAIL_HOST, los correos se escriben en los logs en vez de enviarse
# (útil en desarrollo). En producción, configurar un SMTP real.
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=usuario
# MAIL_PASSWORD=secreto
MAIL_FROM=no-reply@example.com

# Base del frontend: se usa para el enlace de recuperación de contraseña.
FRONTEND_URL=http://localhost:5173
# Vigencia del token de recuperación (minutos).
PASSWORD_RESET_TTL_MINUTES=60

# ── WebSockets ──────────────────────────────────────────────────────
# Habilita el módulo de sockets (namespace /events). Default: false.
# Si el proyecto no los usa, dejarlo en false o borrar la variable.
WS_ENABLED=true

# ── Observabilidad ──────────────────────────────────────────────────
# Swagger en /docs. Default: true en dev, false en producción.
SWAGGER_ENABLED=true
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Entorno de los tests e2e. Sin secretos reales: valores dummy committeados.
# La DB de test se crea y migra sola al correr `pnpm test:e2e`.
NODE_ENV=test

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=base_nestjs_test
DB_SSL=false

JWT_ACCESS_SECRET=test-access-secret-0000000000000000000000
JWT_REFRESH_SECRET=test-refresh-secret-000000000000000000000

# WebSockets: el e2e de events los necesita activos.
WS_ENABLED=true
